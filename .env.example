# Admin login credentials are NOT set here.
# Run `npm run set-password` to create/reset the email + password.
# (Stored hashed in data/admin-user.json)

# Secret for signing session cookies (random string, min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# URL of the Bombino website (for calling the blog API)
WEBSITE_API_URL=http://localhost:3000

# Must match BLOG_ADMIN_SECRET in the website's .env.local
BLOG_ADMIN_SECRET=shared-secret-between-admin-and-website

# ── SMTP (forgot-password OTP email) ────────────────────────
# If these are left blank, OTP codes are logged to the server console
# instead of emailed (dev mode). Works with any SMTP provider:
#   Gmail:    host smtp.gmail.com, port 465, user <addr>, pass <app password>
#   SES:      host email-smtp.<region>.amazonaws.com, port 587
#   Mailtrap: host sandbox.smtp.mailtrap.io, port 2525
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Bombino Admin <no-reply@bombinoexp.com>
